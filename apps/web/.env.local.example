# gRPC-Web (로컬 권장): 이 변수를 비우면 브라우저는 같은 출처 /grpc-web 으로만 요청하고,
# Next(next.config rewrites)가 Envoy(기본 127.0.0.1:8080)로 넘깁니다 → CORS 없음.
# NEXT_PUBLIC_GRPC_WEB_URL=

# 직접 Envoy 로 붙이려면(교차 출처·Envoy CORS 설정 필요):
# NEXT_PUBLIC_GRPC_WEB_URL=http://127.0.0.1:8080

# Envoy 가 다른 호스트/포트일 때만 (rewrites 목적지)
# GRPC_WEB_PROXY_TARGET=http://127.0.0.1:8080

# Next.js 포트는 apps/web/package.json 의 "dev" / "start" 스크립트 -p 값과 맞춤 (기본 3001)
